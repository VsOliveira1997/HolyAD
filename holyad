#!/usr/bin/env python3
# holyad — HTB Active Directory assistant
# usage:
#   holyad --start <ip> [user:password]
#   holyad <tool> [args...]
#   holyad file1.json [file2.json ...]
#   holyad --add "note"
#   holyad --report

import sys, os, subprocess, json, re

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from session import Session
from filter import Filter

HOLYAD_BASE = os.path.expanduser("~/.holyad")
SKILLS_DIR  = os.path.join(os.path.dirname(os.path.abspath(__file__)), "skills")

# bloodhound file extensions — triggers dedicated persistence
BH_EXTENSIONS = {".json", ".zip"}
BH_KEYWORDS   = {"computers", "users", "groups", "domains", "gpos", "ous",
                 "containers", "bloodhound", "sharphound", "rusthound"}

# findings that are generic AD noise — not worth saving, already visible from context
FINDINGS_NOISE = [
    r"^port \d+",
    r"^\d+/tcp\s+open",
    r"^\d+/udp\s+open",
    r"^service.*running.*port",
    r"^(smb|ldap|kerberos|winrm|msrpc|mssql) (service|port|running)",
    r"^target (ip|host|machine)",
    r"^(host|ip|address)[\s:]+\d+\.\d+\.\d+\.\d+",
    r"^nmap scan",
    r"^open port",
]
_NOISE_RE = [re.compile(p, re.IGNORECASE) for p in FINDINGS_NOISE]


def is_noisy_finding(text: str) -> bool:
    return any(r.search(text) for r in _NOISE_RE)


SYSTEM_PROMPT = """You are HolyAD — HTB Active Directory pentesting instructor.

Rules:
- HTB machines have ONE intended path. Think: what did the creator want to teach?
- If a path is blocked or marked as rabbit hole: DROP IT IMMEDIATELY, never return to it.
- Commands must use real values from context — never placeholders.
- BloodHound shows POSSIBLE paths, not guaranteed ones. Cross-reference with --add notes.
- End every response with:
## Key findings
- one bullet per new discovery (users, ports, hashes, ACLs, misconfigs, credentials)
- References: https://www.ired.team | https://0xdf.gitlab.io"""


def is_bloodhound_file(filepath):
    name = os.path.basename(filepath).lower()
    ext  = os.path.splitext(name)[1]
    return ext in BH_EXTENSIONS and any(kw in name for kw in BH_KEYWORDS)


def session_dir_for(ip):
    return os.path.join(HOLYAD_BASE, ip)


def write_claude_md(session_dir, ctx):
    """CLAUDE.md — full context rebuilt on every write. Stateless calls rely on this."""
    ip       = ctx.get("target", "")
    user     = ctx.get("user", "")
    password = ctx.get("pass", "")
    domain   = ctx.get("domain", "")
    done     = ctx.get("sent_commands", [])
    notes    = ctx.get("notes", [])       # --add entries (rabbit holes, observations)
    findings = ctx.get("findings", [])    # auto-extracted from Claude responses

    d = domain or "<domain>"
    lines = [SYSTEM_PROMPT, "\n\n"]

    # ── credentials ───────────────────────────────────────────────
    lines.append("# Session\n")
    lines.append(f"- IP: `{ip}`\n")
    if user:     lines.append(f"- User: `{user}`\n")
    if password: lines.append(f"- Password: `{password}`\n")
    if domain:   lines.append(f"- Domain: `{domain}`\n")
    if user and password:
        cred = f"{domain}\\{user}:{password}" if domain else f"{user}:{password}"
        lines.append(f"- Full cred: `{cred}`\n")

    # ── user notes / rabbit holes (--add) — HIGH WEIGHT ──────────
    if notes:
        lines.append("\n# ⚠️ User Notes & Rabbit Holes — READ CAREFULLY\n")
        lines.append("These are confirmed observations from the user. Treat them as ground truth.\n\n")
        for n in notes:
            lines.append(f"- {n}\n")

    # ── bloodhound analysis — persistent, always present ─────────
    bh_path = os.path.join(session_dir, "bloodhound.md")
    if os.path.exists(bh_path):
        with open(bh_path) as f:
            bh_content = f.read().strip()
        if bh_content:
            BH_MAX = 3000
            if len(bh_content) > BH_MAX:
                bh_content = (bh_content[:BH_MAX] +
                    f"\n\n[... bloodhound analysis truncated — full analysis in bloodhound.md ...]")
            lines.append("\n# BloodHound Analysis\n")
            lines.append("⚠️ BloodHound shows POSSIBLE paths. Cross-reference with User Notes above.\n\n")
            lines.append(bh_content + "\n")

    # ── auto-extracted findings ───────────────────────────────────
    if findings:
        lines.append("\n# Discovered Findings\n")
        for f in findings:
            lines.append(f"- {f}\n")

    # ── commands already run — CRITICAL — never repeat ────────────
    if done:
        lines.append("\n# ✅ Commands Analyzed by Claude — DO NOT REPEAT\n")
        for entry in done:
            # support both old string format and new dict format
            cmd = entry if isinstance(entry, str) else entry.get("cmd", "")
            lines.append(f"- `{cmd}`\n")

    failed = ctx.get("failed_commands", [])
    if failed:
        inline = ", ".join(f"`{c}`" for c in failed[-20:])
        lines.append(f"\n# ❌ Commands With No Useful Output — DO NOT RETRY\n")
        lines.append(f"{inline}\n")

    # ── session log (compact — key findings only) ───────────────
    log_path = os.path.join(session_dir, "session.md")
    if os.path.exists(log_path):
        with open(log_path) as f:
            log = f.read().strip()
        if log:
            LOG_MAX = 2000
            if len(log) > LOG_MAX:
                log = "[... earlier entries trimmed — see session.md for full log ...]\n" + log[-LOG_MAX:]
            lines.append("\n# Session Log (key findings per step)\n")
            lines.append(log + "\n")



    with open(os.path.join(session_dir, "CLAUDE.md"), "w") as f:
        f.writelines(lines)


def append_session_log(session_dir, label, findings_only):
    """Save only key findings bullets to session.md — keeps log compact."""
    if not findings_only:
        return
    with open(os.path.join(session_dir, "session.md"), "a") as f:
        f.write(f"\n### {label}\n")
        for b in findings_only:
            f.write(f"- {b}\n")


def save_bloodhound_analysis(session_dir, label, response):
    """Persist BloodHound analysis — overwrites to keep context lean."""
    with open(os.path.join(session_dir, "bloodhound.md"), "w") as f:
        f.write(f"### {label}\n{response}\n")


def call_claude(message, session_dir):
    import threading, itertools, time

    TIMEOUT = 120  # abort if no response in 2 minutes

    cmd = ["claude", "--bare", "--dangerously-skip-permissions", "--allowedTools", "Skill,Read",
           "--add-dir", SKILLS_DIR, "--output-format", "json", "-p"]

    stop = threading.Event()
    start_time = time.time()

    def spin():
        for c in itertools.cycle("⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"):
            if stop.is_set(): break
            elapsed = int(time.time() - start_time)
            print(f"\r  {c} thinking... {elapsed}s", end="", flush=True)
            time.sleep(0.1)
        print("\r" + " " * 30 + "\r", end="", flush=True)

    t = threading.Thread(target=spin, daemon=True)
    t.start()

    try:
        proc = subprocess.run(cmd, input=message, capture_output=True, text=True,
                              cwd=session_dir, timeout=TIMEOUT)
        stop.set()
        t.join()
    except subprocess.TimeoutExpired:
        stop.set()
        t.join()
        print(f"\n  [holyad] call timed out after {TIMEOUT}s — no response received")
        print("  tip: try again, or use 'holyad --add' to mark dead ends and trim context\n")
        return None, {}

    stdout = proc.stdout.strip()
    if not stdout:
        if proc.stderr.strip():
            print(f"\n  [holyad] error: {proc.stderr.strip()[:300]}\n")
        return None, {}

    # parse JSON output for response text + token usage
    try:
        data = json.loads(stdout)
        response_text = data.get("result", "").strip()
        usage = data.get("usage", {})
    except (json.JSONDecodeError, ValueError):
        response_text = stdout  # fallback: treat as plain text
        usage = {}

    if not response_text:
        return None, {}

    return response_text, usage


def print_token_info(usage, session):
    """Display token usage for this call and update session cumulative totals."""
    inp = usage.get("input_tokens", 0)
    out = usage.get("output_tokens", 0)
    if not inp and not out:
        return
    call_total = inp + out
    ctx = session.load()
    tu = ctx.get("token_usage", {"input": 0, "output": 0})
    tu["input"]  += inp
    tu["output"] += out
    ctx["token_usage"] = tu
    session.save(ctx)
    session_total = tu["input"] + tu["output"]
    print(f"  [tokens] this call: {inp:,} in / {out:,} out ({call_total:,} total)"
          f"  |  session: {session_total:,}")


def context_size_hint(session_dir):
    """Estimate input token count from CLAUDE.md size (rough: 4 chars ≈ 1 token)."""
    p = os.path.join(session_dir, "CLAUDE.md")
    if not os.path.exists(p):
        return 0
    return os.path.getsize(p) // 4


def display(response, label=""):
    print()
    print("━" * 60)
    if label:
        print(f"  {label}")
        print("━" * 60)
    print()
    print(response)
    print()


def extract_findings(response, session, session_dir):
    if "## Key findings" not in response:
        return
    section = response.split("## Key findings")[-1].strip()
    new = []
    for line in section.split("\n"):
        line = line.strip()
        if line.startswith("##"):
            break
        if line.startswith("-") and len(line) > 2:
            f = line[1:].strip()
            if f:
                new.append(f)
    # drop generic noise — port open, service running, etc.
    new = [f for f in new if not is_noisy_finding(f)]
    if not new:
        return
    ctx = session.load()
    existing = ctx.get("findings", [])
    for f in new:
        if f not in existing:
            existing.append(f)
    ctx["findings"] = existing
    session.save(ctx)
    write_claude_md(session_dir, ctx)
    print(f"  [holyad] {len(new)} finding(s) saved")


# ── handlers ──────────────────────────────────────────────────────────────────

def handle_start(args):
    if not args:
        print("usage: holyad --start <ip> [user:password]"); sys.exit(1)
    ip    = args[0]
    creds = args[1] if len(args) > 1 else None
    sdir  = session_dir_for(ip)
    os.makedirs(sdir, exist_ok=True)

    # wipe session files but keep bloodhound.md if user wants to preserve it
    for f in ["CLAUDE.md", "last_output.txt", "session.md"]:
        p = os.path.join(sdir, f)
        if os.path.exists(p): os.remove(p)

    session = Session(ip)
    session.init(ip, creds)
    ctx = session.load()
    write_claude_md(sdir, ctx)

    print(f"\n  session started  →  {sdir}")
    print(f"  target : {ip}")
    print(f"  type   : {ctx['type']}")
    if ctx.get('user'): print(f"  user   : {ctx['user']}")
    print()


def handle_add(args):
    """Save a user note (rabbit hole, observation, confirmed fact)."""
    if not args:
        print('usage: holyad --add "note"'); sys.exit(1)
    note    = " ".join(args)
    session = Session()
    ctx     = session.load()
    if not ctx.get("target"):
        print("error: no active session"); sys.exit(1)

    ctx.setdefault("notes", []).append(note)
    session.save(ctx)
    write_claude_md(session.session_dir, ctx)
    print(f"\n  note saved: {note}\n")


def handle_report():
    session = Session()
    ctx     = session.load()
    if not ctx.get("target"):
        print("error: no active session"); sys.exit(1)
    sdir    = session.session_dir
    msg     = "Generate a concise pentest report. Include: techniques used, why they worked, what was found, lessons learned."
    ctx_tokens     = context_size_hint(sdir)
    payload_tokens = len(msg) // 4
    total_tokens   = ctx_tokens + payload_tokens
    print(f"  [context] ~{ctx_tokens:,} (context) + ~{payload_tokens:,} (payload) = ~{total_tokens:,} tokens going in")
    response, usage = call_claude(msg, sdir)
    if not response:
        print("  [holyad] no response received — try again\n")
        return
    print_token_info(usage, session)
    session.save_report(response)
    display(response, "session report")
    print(f"  report saved to {sdir}/report.md")


def handle_input(args):
    session = Session()
    ctx     = session.load()
    if not ctx.get("target"):
        print("error: no active session — run 'holyad --start <ip>' first"); sys.exit(1)
    sdir = session.session_dir

    all_files    = all(os.path.isfile(a) for a in args)
    is_bh        = all_files and any(is_bloodhound_file(a) for a in args)

    if all_files:
        print(f"\n  loading {len(args)} file(s)...", end="", flush=True)
        MAX_FILE_CHARS = 8000
        payload = ""
        for fp in args:
            with open(fp, "r", errors="replace") as f:
                file_content = f.read()
            if len(file_content) > MAX_FILE_CHARS:
                half = MAX_FILE_CHARS // 2
                file_content = (file_content[:half] +
                    f"\n\n[... {len(file_content) - MAX_FILE_CHARS} chars truncated ...]\n\n" +
                    file_content[-half:])
            payload += f"=== {os.path.basename(fp)} ===\n{file_content}\n\n"
        print(f" {len(payload)} bytes ready")

        if is_bh:
            message = (
                "Analyze these BloodHound files. Extract:\n"
                "1. Attack paths to Domain Admin (shortest paths from owned users)\n"
                "2. ACL edges: GenericAll, GenericWrite, WriteSPN, ForceChangePassword, AddSelf, DCSync\n"
                "3. Kerberoastable / AS-REP roastable accounts\n"
                "4. GMSA accounts and who can read them\n"
                "5. ADCS enrollment rights\n"
                "6. Any Pre-Windows 2000 computer accounts\n\n"
                "Cross-reference with user notes in context — if a path is marked as rabbit hole, say so.\n\n"
                f"{payload}"
            )
            label = "bloodhound: " + ", ".join(os.path.basename(a) for a in args)
        else:
            message = f"Analyze these files and suggest the next step:\n\n{payload}"
            label   = "files: " + ", ".join(os.path.basename(a) for a in args)

    else:
        print(f"\n  running: {' '.join(args)}\n")
        out_lines = []
        proc = subprocess.Popen(args, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
        for line in proc.stdout:
            print(line, end="")
            out_lines.append(line)
        proc.wait()
        output = "".join(out_lines)

        cmd_str = " ".join(args)
        output  = Filter.compress(output)

        if not Filter.should_send(output, cmd_str):
            print("\n  [holyad] output filtered — nothing relevant to analyze")
            # track as failed so Claude knows not to retry
            ctx2   = session.load()
            failed = ctx2.get("failed_commands", [])
            if cmd_str not in failed:
                failed.append(cmd_str)
                ctx2["failed_commands"] = failed
                session.save(ctx2)
            return

        ctx2  = session.load()
        cmds  = ctx2.get("sent_commands", [])
        known = [e if isinstance(e, str) else e.get("cmd", "") for e in cmds]
        if cmd_str not in known:
            cmds.append({"cmd": cmd_str, "status": "success"})
            ctx2["sent_commands"] = cmds
            session.save(ctx2)
            write_claude_md(sdir, ctx2)

        with open(os.path.join(sdir, "last_output.txt"), "w") as f:
            f.write(f"command: {cmd_str}\n\n{output}")

        # truncate large outputs — blobs, hashes, base64 blow up tokens
        MAX_CHARS = 6000  # tighter now that output is already compressed
        if len(output) > MAX_CHARS:
            half = MAX_CHARS // 2
            output_trimmed = (output[:half] +
                f"\n\n[... {len(output) - MAX_CHARS} chars truncated — full output in last_output.txt ...]\n\n" +
                output[-half:])
            print(f"\n  [holyad] output truncated ({len(output)} → {MAX_CHARS} chars)")
        else:
            output_trimmed = output

        message = f"Analyze this output and suggest the next step:\n\ncommand: {cmd_str}\n\n{output_trimmed}"
        label   = cmd_str

    ctx_tokens     = context_size_hint(sdir)
    payload_tokens = len(message) // 4
    total_tokens   = ctx_tokens + payload_tokens
    print(f"  [context] ~{ctx_tokens:,} (context) + ~{payload_tokens:,} (payload) = ~{total_tokens:,} tokens going in")
    response, usage = call_claude(message, sdir)
    if not response:
        print("  [holyad] no response received — try again\n")
        return
    print_token_info(usage, session)
    session.log_response(response)

    # extract key findings bullets for compact session log
    bullets = []
    if "## Key findings" in response:
        section = response.split("## Key findings")[-1].strip()
        for line in section.split("\n"):
            line = line.strip()
            if line.startswith("##"): break
            if line.startswith("-") and len(line) > 2:
                bullets.append(line[1:].strip())

    if is_bh:
        save_bloodhound_analysis(sdir, label, response)
        print("  [holyad] bloodhound analysis saved to bloodhound.md")
    else:
        append_session_log(sdir, label, bullets)

    display(response, label)
    extract_findings(response, session, sdir)

    # after bloodhound, rebuild CLAUDE.md so it includes the new analysis
    if is_bh:
        write_claude_md(sdir, session.load())


def handle_status():
    session = Session()
    ctx     = session.load()
    if not ctx.get("target"):
        print("error: no active session"); sys.exit(1)
    sdir = session.session_dir
    tu   = ctx.get("token_usage", {"input": 0, "output": 0})
    session_total = tu["input"] + tu["output"]
    ctx_tokens    = context_size_hint(sdir)
    print(f"\n  target   : {ctx['target']}")
    print(f"  tokens   : {session_total:,} used this session  (in: {tu['input']:,}  out: {tu['output']:,})")
    print(f"  context  : ~{ctx_tokens:,} tokens queued for next call")
    print(f"  findings : {len(ctx.get('findings', []))}")
    print(f"  commands : {len(ctx.get('sent_commands', []))} tracked")
    if ctx.get("notes"):
        print(f"  notes    : {len(ctx['notes'])}")
    print()


def main():
    args = sys.argv[1:]
    if not args:
        print("usage:")
        print("  holyad --start <ip> [user:password]")
        print("  holyad --status")
        print("  holyad <tool> [args...]")
        print("  holyad file1.json [file2.json ...]")
        print('  holyad --add "rabbit hole or observation"')
        print("  holyad --report")
        sys.exit(0)

    if   args[0] == "--start":  handle_start(args[1:])
    elif args[0] == "--report": handle_report()
    elif args[0] == "--add":    handle_add(args[1:])
    elif args[0] == "--status": handle_status()
    else:                       handle_input(args)

if __name__ == "__main__":
    main()